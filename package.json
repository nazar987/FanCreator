{
  "name": "fancreator",
  "version": "2.1.5",
  "description": "FanCreator — приложение для написания историй и фанфиков",
  "author": "Nazio",
  "main": "./out/main/index.js",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build && electron-builder",
    "build:dir": "electron-vite build && electron-builder --dir",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@fontsource/cormorant-sc": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "better-sqlite3": "^11.8.1",
    "docx": "^9.5.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "html-to-docx": "^1.8.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.11.0"
  },
  "devDependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@tiptap/core": "^3.7.2",
    "@tiptap/extension-character-count": "^3.7.2",
    "@tiptap/extension-color": "^3.7.2",
    "@tiptap/extension-font-family": "^3.22.2",
    "@tiptap/extension-highlight": "^3.7.2",
    "@tiptap/extension-image": "^3.7.2",
    "@tiptap/extension-link": "^3.7.2",
    "@tiptap/extension-placeholder": "^3.7.2",
    "@tiptap/extension-table": "^3.7.2",
    "@tiptap/extension-table-cell": "^3.7.2",
    "@tiptap/extension-table-header": "^3.7.2",
    "@tiptap/extension-table-row": "^3.7.2",
    "@tiptap/extension-text-align": "^3.14.0",
    "@tiptap/extension-text-style": "^3.22.2",
    "@tiptap/extension-typography": "^3.7.2",
    "@tiptap/extension-underline": "^3.7.2",
    "@tiptap/pm": "^3.7.2",
    "@tiptap/react": "^3.7.2",
    "@tiptap/starter-kit": "^3.7.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.546.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "tiptap-pagination-plus": "^3.0.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
